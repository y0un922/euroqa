# Auth (leave ACCESS_PASSWORD empty to disable login)
ACCESS_PASSWORD=
AUTH_SECRET_KEY=change-me-to-a-random-string
AUTH_TOKEN_TTL_SECONDS=86400

# LLM
LLM_API_KEY=your-api-key
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
CONTEXTUALIZE_LLM_API_KEY=
CONTEXTUALIZE_LLM_BASE_URL=
CONTEXTUALIZE_LLM_MODEL=
CONTEXTUALIZE_CONCURRENCY=8
CONTEXTUALIZE_RETRY_ATTEMPTS=2

# Embedding
# local: load local model from EMBEDDING_MODEL
# remote: accepts either a full embeddings endpoint or an OpenAI-compatible base URL like https://api.siliconflow.cn/v1
EMBEDDING_PROVIDER=local
EMBEDDING_MODEL=BAAI/bge-m3
EMBEDDING_API_URL=
EMBEDDING_API_KEY=
EMBEDDING_REQUEST_TIMEOUT_SECONDS=120
EMBEDDING_BATCH_SIZE=8

# Rerank
# local: load local model from RERANK_MODEL
# remote: accepts either a full rerank endpoint or an OpenAI-compatible base URL like https://api.siliconflow.cn/v1
RERANK_PROVIDER=local
RERANK_MODEL=BAAI/bge-reranker-v2-m3
RERANK_API_URL=
RERANK_API_KEY=
RERANK_REQUEST_TIMEOUT_SECONDS=120

# MinerU
# local: use self-hosted MinerU service via MINERU_API_URL
# official: use mineru.net hosted API via MINERU_API_TOKEN
MINERU_PROVIDER=local

# Local MinerU mode
MINERU_API_URL=http://localhost:8000
MINERU_BACKEND=hybrid-http-client

# Official MinerU mode
MINERU_OFFICIAL_BASE_URL=https://mineru.net
MINERU_API_TOKEN=
MINERU_OFFICIAL_MODEL_VERSION=pipeline

# Shared MinerU options
MINERU_ENABLE_FORMULA=true
MINERU_ENABLE_TABLE=true
MINERU_LANGUAGE=ch
MINERU_IS_OCR=false
MINERU_REQUEST_TIMEOUT_SECONDS=600
MINERU_POLL_INTERVAL_SECONDS=5

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# Elasticsearch
ES_URL=http://localhost:9200

# Paths
PDF_DIR=data/pdfs
PARSED_DIR=data/parsed
DEBUG_PIPELINE_DIR=data/debug_runs
GLOSSARY_PATH=data/glossary.json
